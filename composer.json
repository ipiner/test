{
  "name": "ipiner/pin",
  "description": "The pin library",
  "keywords": ["framework", "laravel", "pin"],
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "ext-ctype": "*",
    "ext-gd": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-redis": "*",
    "firebase/php-jwt": "^7.0",
    "godruoyi/php-snowflake": "^3.0",
    "intervention/image": "^3.11",
    "laravel/framework": "^13.0",
    "laravel/sanctum": "^4.0"
  },
  "require-dev": {
    "dedoc/scramble": "^0.13.22",
    "laravel/facade-documenter": "dev-main",
    "laravel/pint": "^1.15",
    "orchestra/testbench": "^11.1",
    "pestphp/pest": "^4.7",
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^12"
  },
  "autoload": {
    "psr-4": {
      "Pin\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\": "tests/laravel/app",
      "Pin\\Tests\\": "tests"
    }
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [{
    "name": "facade-documenter",
    "type": "vcs",
    "url": "git@github.com:laravel/facade-documenter.git"
  }]
}
